  "notes": {
    "usage": "This hook will suggest the planning-with-files skill when you're starting a complex task",
    "trigger_conditions": "Tasks requiring 3+ steps, research work, or when you mention planning/organization",
    "expansion": "Add more skills and rules as needed. See https://github.com/diet103/claude-code-infrastructure-showcase for examples",
    "enforcement_types": {
      "auto": "Detected → invoke immediately, no confirmation needed",
      "suggest-default-yes": "Suggest with default YES — user can skip but defaults to execute",
      "suggest": "Skill suggestion appears but doesn't block execution",
      "block": "Requires skill to be used before proceeding (guardrail)",
      "warn": "Shows warning but allows proceeding"
    },
    "priority_levels": {
      "critical": "Highest - Always trigger when matched",
      "high": "Important - Trigger for most matches",
      "medium": "Moderate - Trigger for clear matches",
      "low": "Optional - Trigger only for explicit matches"
    }
  }
