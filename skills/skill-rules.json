  "skills": {
    "planning-with-files": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "high",
      "description": "Manus AI workflow - file-based task planning for complex multi-step tasks",
      "promptTriggers": {
        "keywords": [
          "complex task",
          "multi-step",
          "long task",
          "research task",
          "build project",
          "implement feature",
          "create system",
          "planning",
          "organize work",
          "track progress",
          "task plan",
          "task planning"
        ],
        "intentPatterns": [
          "(create|build|implement|develop).*?(feature|system|module|component)",
          "(plan|organize|structure).*?(task|work|project)",
          "(research|analyze|investigate).*?(and|then)",
          "help.*?implement.*?(complete|full|entire)"
        ]
      }
    },
