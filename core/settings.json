{
  "env": {},
  "permissions": {
    "allow": [
      "Bash(*)",
      "mcp__filesystem__write_file",
      "mcp__filesystem__edit_file",
      "mcp__filesystem__create_directory",
      "mcp__filesystem__move_file",
      "mcp__filesystem__read_file",
      "mcp__filesystem__read_multiple_files",
      "mcp__filesystem__list_directory",
      "mcp__filesystem__list_directory_with_sizes",
      "mcp__filesystem__directory_tree",
      "mcp__filesystem__search_files",
      "mcp__filesystem__get_file_info",
      "mcp__filesystem__list_allowed_directories",
      "Bash(cp*)",
      "Bash(mv*)",
      "Bash(rm*)",
      "Bash(git*)",
      "Bash(zip*)",
      "Bash(unzip*)",
      "Bash(grep*)",
      "Bash(find*)",
      "Bash(jq*)",
      "WebSearch",
      "WebFetch"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"__HOME__/.claude/hooks/gsd-check-update.js\"",
            "timeout": 15
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"__HOME__/.claude/hooks/forge-session-start.js\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit|Agent|Task|Skill",
        "hooks": [
          {
            "type": "command",
            "command": "node \"__HOME__/.claude/hooks/forge-context-bridge.js\"",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "Skill|Agent|Task|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"__HOME__/.claude/hooks/forge-quality-pipeline.js\"",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"__HOME__/.claude/hooks/forge-auto-fix.js\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"__HOME__/.claude/hooks/forge-state-sync.js\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"__HOME__/.claude/hooks/gsd-prompt-guard.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"__HOME__/.claude/hooks/git-safety.sh\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"__HOME__/.claude/hooks/pre-tool-use-guard.sh\"",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash -c 'plugin_dir=$(ls -d \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}\"/plugins/cache/jarrodwatts/claude-hud/*/ 2>/dev/null | tail -1); exec \"__HOME__/.bun/bin/bun\" \"${plugin_dir}src/index.ts\"'"
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "claude-hud@jarrodwatts": true,
    "pua@pua-skills": true,
    "discord@claude-plugins-official": true
  },
  "effortLevel": "high",
  "autoUpdatesChannel": "latest",
  "autoDreamEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "model": "opusplan"
}
